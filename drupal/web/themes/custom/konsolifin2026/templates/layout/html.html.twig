{#
/**
 * @file
 * KonsoliFIN 2026 html template.
 */
#}
<!DOCTYPE html>
<html{{ html_attributes }}>
  <head>
    <link rel='icon' href='/{{ active_theme_path() }}/icons/favicon.ico'>
    <head-placeholder token="{{ placeholder_token }}">
    <title>{{ head_title|safe_join(' | ') }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#0d0d0f">
    <link rel="alternate" type="application/rss+xml" title="KonsoliFIN / Uusin sisältö" href="https://www.konsolifin.net/rss.xml">
    <link rel="alternate" type="application/rss+xml" title="KonsoliFIN / Uutiset" href="https://www.konsolifin.net/uutiset.rss">
    <link rel="alternate" type="application/rss+xml" title="KonsoliFIN / Peliarvostelut" href="https://www.konsolifin.net/peliarvostelut.rss">
    <link rel="alternate" type="application/rss+xml" title="KonsoliFIN / Blogit ja artikkelit" href="https://www.konsolifin.net/jutut.xml">
    <link rel="alternate" type="application/rss+xml" title="KonsoliFIN / Podcastit" href="https://www.konsolifin.net/podcast/podcast.rss">
    <css-placeholder token="{{ placeholder_token }}">
    <js-placeholder token="{{ placeholder_token }}">
  </head>
  <body{{ attributes }}>
    {#
      Keyboard navigation/accessibility link to main content section in
      page.html.twig.
    #}
    <a href="#main-content" class="visually-hidden focusable skip-link">
      {{ 'Siirry sisältöön'|t }}
    </a>
    {{ page_top }}
    {{ page }}
    {{ page_bottom }}
    <js-bottom-placeholder token="{{ placeholder_token }}">
  </body>
</html>

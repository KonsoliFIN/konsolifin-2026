{#
/**
 * @file
 * Template for peli taxonomy term pages.
 *
 * Available variables:
 * - peli_julkaisut: array — grouped julkaisu nodes by type.
 * - peli_no_julkaisut_message: string — message shown when no releases exist.
 * - peli_add_julkaisu_url: string — URL to add a julkaisu.
 */
#}
<div class="taxonomy-term taxonomy-term--peli">
  {# Render the base fields of the term first #}
  <div class="peli-content">
    {{ content }}
  </div>

  <div class="peli-julkaisut-section">
    <h2>{{ 'Releases'|t }}</h2>

    {% if peli_julkaisut %}
      {% for group_key, group in peli_julkaisut %}
        <div class="peli-julkaisut-group peli-julkaisut-group--{{ group_key }}">
          <h3>{{ group.label }}</h3>
          <ul class="peli-julkaisut__list">
            {% for item in group.items %}
              <li class="peli-julkaisut__item">
                <a href="{{ item.url }}" class="peli-julkaisut__link">{{ item.title }}</a>
                {% if item.date_display %}
                  <span class="peli-julkaisut__date">{{ item.date_display }}</span>
                {% endif %}
                {% if item.platforms %}
                  <span class="peli-julkaisut__platforms">({{ item.platforms|join(', ') }})</span>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endfor %}
    {% else %}
      <p class="peli-julkaisut__empty">{{ peli_no_julkaisut_message }}</p>
    {% endif %}

    {% if peli_add_julkaisu_url %}
      <div class="peli-julkaisut__add">
        <a href="{{ peli_add_julkaisu_url }}" class="use-ajax button" data-dialog-type="modal">{{ 'Add Release'|t }}</a>
      </div>
    {% endif %}
  </div>
</div>

<?php

/**
 * @file
 * Hook implementations for the konsolifin_term_page module.
 */

declare (strict_types = 1);

use Drupal\Core\Url;
use Drupal\konsolifin_term_page\FranchiseHandler;
use Drupal\konsolifin_term_page\PeliHandler;
use Drupal\views\Plugin\views\query\QueryPluginBase;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_theme().
 */
function konsolifin_term_page_theme(): array {
  return [
    'taxonomy_term__franchise' => [
      'base hook' => 'taxonomy_term',
    ],
    'taxonomy_term__peli'      => [
      'base hook' => 'taxonomy_term',
    ],
    'games_page'               => [
      'variables' => [
        'top_games'            => [],
        'top_games_heading'    => '',
        'search_form'          => [],
        'upcoming_releases'    => [],
        'most_discussed'       => [],
        'most_discussed_error' => NULL,
      ],
      'template'  => 'games-page',
    ],
  ];
}

/**
 * Implements hook_preprocess_taxonomy_term().
 */
function konsolifin_term_page_preprocess_taxonomy_term(array &$variables): void {
  $term     = $variables['term'];
  $handlers = _konsolifin_term_page_get_handlers();
  $vid      = $term->bundle();
  if (isset($handlers[$vid])) {
    $handlers[$vid]->preprocess($variables, $term);
  }
}

/**
 * Returns a map of vocabulary ID to handler instance.
 *
 * @return \Drupal\konsolifin_term_page\VocabularyHandlerInterface[]
 *   Keyed by vocabulary ID.
 */
function _konsolifin_term_page_get_handlers(): array {
  static $handlers;

  if (! isset($handlers)) {
    $franchiseHandler = new FranchiseHandler();
    $peliHandler      = new PeliHandler();
    $handlers         = [
      $franchiseHandler->getVocabularyId() => $franchiseHandler,
      $peliHandler->getVocabularyId()      => $peliHandler,
    ];
  }

  return $handlers;
}

/**
 * Implements hook_theme_suggestions_taxonomy_term_alter().
 */
function konsolifin_term_page_theme_suggestions_taxonomy_term_alter(array &$suggestions, array $variables): void {
  $term   = $variables['elements']['#taxonomy_term'];
  $bundle = $term->bundle();
  if ($bundle === 'franchise' || $bundle === 'peli') {
    $suggestions[] = 'taxonomy_term__' . $bundle;
  }
}

/**
 * Implements hook_views_query_alter().
 */
function konsolifin_term_page_views_query_alter(ViewExecutable $view, QueryPluginBase $query): void {
  if ($view->id() === 'taxonomy_term') {
    $term = \Drupal::routeMatch()->getParameter('taxonomy_term');
    if ($term instanceof \Drupal\taxonomy\TermInterface  && $term->bundle() === 'peli') {
      // Exclude 'julkaisu' nodes from the 'peli' taxonomy term page views.
      $query->addWhere('konsolifin_term_page', 'node_field_data.type', 'julkaisu', '!=');
    }
  }
}

function konsolifin_term_page_form_alter(&$form, &$form_state, $form_id) {
  \Drupal::logger('konsolifin_term_page')->debug('Opening form @form_id', ['@form_id' => $form_id]);

  if ($form_id === 'taxonomy_term_peli_form') {
    if (isset($form['field_forum_ketju']['widget'][0]['value'])) {
      $form['field_forum_ketju']['widget'][0]['value']['#autocomplete_route_name'] = 'konsolifin_term_page.forum_threads_query';
    }
  }
}

/**
 * Implements hook_preprocess_HOOK() for field.
 */
function konsolifin_term_page_preprocess_field(array &$variables): void {
  if ($variables['field_name'] === 'field_forum_ketju') {
    $entity = $variables['element']['#object'];
    if ($entity && $entity->hasField('field_forum_ketju')) {
      foreach ($variables['items'] as $delta => $item) {
        $thread_id = $entity->get('field_forum_ketju')->get($delta)->value;
        if (! empty($thread_id)) {
          $variables['items'][$delta]['content'] = [
            '#type'  => 'link',
            '#title' => t('Forum-ketju'),
            '#url'   => Url::fromUri('https://forum.konsolifin.net/threads/' . $thread_id),
          ];
        }
      }
    }
  }
}

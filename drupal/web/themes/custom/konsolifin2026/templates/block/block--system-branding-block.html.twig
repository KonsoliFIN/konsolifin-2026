{#
/**
 * @file
 * Site branding block template.
 */
#}
<div{{ attributes.addClass('site-branding') }}>
  {% if site_logo %}
    <a href="{{ path('<front>') }}" class="site-branding__logo" rel="home" aria-label="{{ 'Etusivu'|t }}">
      <img src="{{ site_logo }}" alt="{{ 'KonsoliFIN logo'|t }}">
    </a>
  {% endif %}
  {% if site_name %}
    <a href="{{ path('<front>') }}" class="site-branding__name" rel="home">
      Konsoli<span>FIN</span>
    </a>
  {% endif %}
</div>

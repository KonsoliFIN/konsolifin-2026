{#
/**
 * @file
 * KonsoliFIN 2026 page template.
 *
 * The content_nav links appear in two places:
 * - Inside the off-canvas primary-nav on mobile
 * - As a horizontal bar above page.content on desktop
 */
#}

{# --- Content navigation links (edit in one place) --- #}
{% set content_nav_links = [
  { url: '//forum.konsolifin.net', label: 'Forum'|t },
  { url: '/pelit', label: 'Pelit'|t },
  { url: '/peliarvostelut', label: 'Arvostelut'|t },
  { url: '/uutiset', label: 'Uutiset'|t },
  { url: '/podcastit', label: 'Podcastit'|t },
  { url: 'https://www.youtube.com/@KonsolifinMedia', label: 'Videot'|t },
  { url: '/jutut', label: 'Muut jutut'|t },
] %}

<a href="#main-content" class="skip-link visually-hidden focusable">
  {{ 'Siirry sisältöön'|t }}
</a>

<header class="site-header" role="banner">
  <div class="site-header__inner">
    {% if page.header %}
      {{ page.header }}
    {% endif %}

    <nav class="primary-nav" aria-label="{{ 'Päävalikko'|t }}">
      {% if page.primary_menu %}
        {{ page.primary_menu }}
      {% endif %}

      {# Content nav inside off-canvas panel (mobile only) #}
      <div class="content-nav content-nav--mobile" aria-label="{{ 'Sisältövalikko'|t }}">
        <span class="content-nav__heading">{{ 'Sisältö'|t }}</span>
        <ul class="content-nav__list">
          {% for link in content_nav_links %}
            <li class="content-nav__item">
              <a href="{{ link.url }}">{{ link.label }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>
    </nav>
    <div class="primary-nav__overlay" data-visible="false"></div>

    <button class="menu-toggle" aria-expanded="false" aria-controls="primary-nav" aria-label="{{ 'Avaa valikko'|t }}">
      <span class="menu-toggle__icon"></span>
    </button>
  </div>
</header>

<div class="layout-container">
  {# Content nav bar (desktop only) #}
  <nav class="content-nav content-nav--desktop" aria-label="{{ 'Sisältövalikko'|t }}">
    <ul class="content-nav__list">
      {% for link in content_nav_links %}
        <li class="content-nav__item">
          <a href="{{ link.url }}">{{ link.label }}</a>
        </li>
      {% endfor %}
    </ul>
  </nav>

  <div class="layout-content-wrapper">
    <main id="main-content" class="layout-main" role="main">
      {{ page.content }}
    </main>
  </div>

  {% if page.content_bottom %}
    <div class="region-content-bottom">
      {{ page.content_bottom }}
    </div>
  {% endif %}
</div>

<footer class="site-footer" role="contentinfo">
  <div class="site-footer__inner">
    <div class="site-footer__grid">
      {% if page.footer_first %}
        <div class="site-footer__column">
          {{ page.footer_first }}
        </div>
      {% endif %}
      {% if page.footer_second %}
        <div class="site-footer__column">
          {{ page.footer_second }}
        </div>
      {% endif %}
      {% if page.footer_third %}
        <div class="site-footer__column">
          {{ page.footer_third }}
        </div>
      {% endif %}
    </div>
    {% if page.footer %}
      <div class="site-footer__bottom">
        {{ page.footer }}
      </div>
    {% endif %}
  </div>
</footer>
